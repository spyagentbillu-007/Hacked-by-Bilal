<!DOCTYPE html>
<html>
<head>
    <title>System Access</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&display=swap" rel="stylesheet">
    <style>
        html, body {
            margin:0; padding:0;
            height:100%; width:100%;
            background:black; color:#00FF00;
            font-family:'Orbitron',sans-serif;
            text-align:center; overflow:hidden;
        }
        #mainLogo{
            font-size:80px; color:#00FF00;
            text-shadow:0 0 20px lime,0 0 40px green,0 0 60px red;
            margin-top:50px; animation:flicker 1.5s infinite;
        }
        @keyframes flicker{
            0%,19%,21%,23%,25%,54%,56%,100%{opacity:1;}
            20%,22%,24%,55%{opacity:0.3;}
        }
        #developer{font-size:22px;font-weight:bold;margin-bottom:30px;}
        #developer span{animation:rainbow 3s infinite;}
        @keyframes rainbow{
            0%{color:red;}15%{color:orange;}30%{color:yellow;}45%{color:green;}
            60%{color:cyan;}75%{color:blue;}90%{color:magenta;}100%{color:red;}
        }
        h1{font-size:50px;color:red;text-shadow:0 0 15px red,0 0 25px darkred,0 0 35px crimson;animation:alertFlash 1s infinite;}
        @keyframes alertFlash{0%,49%,100%{opacity:1;}50%,99%{opacity:0.2;}}
        #hackText{font-size:24px;margin-top:30px;min-height:50px;color:#00FF00;text-shadow:0 0 10px lime,0 0 20px green;}
        .blink{animation:blink 1s infinite;}
        @keyframes blink{0%{opacity:1;}50%{opacity:0;}100%{opacity:1;}}
        /* Banner */
        #banner{display:none;background:linear-gradient(90deg,red,orange,yellow,lime,cyan,blue,magenta);
            padding:50px 20px;margin-top:30px;color:black;font-size:70px;font-weight:bold;text-shadow:0 0 15px white,0 0 25px yellow;animation:bannerGlow 2s infinite alternate;}
        @keyframes bannerGlow{0%{text-shadow:0 0 15px white,0 0 25px yellow;}100%{text-shadow:0 0 50px white,0 0 100px yellow;}}
        #bannerLines{font-size:22px;color:#00FF00;text-shadow:0 0 5px lime;margin-top:20px;display:none;}
        .redFlash{animation:redFlashAnim 0.5s infinite alternate;}
        @keyframes redFlashAnim{0%{background:black;}50%{background:darkred;}100%{background:black;}}
        .shake{animation:shakeAnim 0.5s infinite;}
        @keyframes shakeAnim{0%{transform:translate(0,0);}20%{transform:translate(-10px,10px);}40%{transform:translate(10px,-10px);}60%{transform:translate(-10px,10px);}80%{transform:translate(10px,-10px);}100%{transform:translate(0,0);}}
    </style>
</head>
<body>

<div id="mainLogo">HACKED BY BILAL</div>
<div id="developer"><span>Developer Mr. Bilal – Official Tricker Coding Master</span></div>
<h1>SYSTEM HACKING...</h1>
<p id="hackText"></p>
<p class="blink">█ █ █ █ █</p>

<!-- Banner -->
<div id="banner">MR. BILAL</div>
<div id="bannerLines">
Initializing secure protocol…<br>
Bypassing firewalls…<br>
Injecting malware…<br>
Accessing private network…<br>
Decrypting files…<br>
Locating target…<br>
SYSTEM BREACH SUCCESSFUL
</div>

<!-- Sounds -->
<audio id="beepSound" src="https://www.soundjay.com/button/sounds/beep-07.mp3" autoplay></audio>
<audio id="successSound" src="https://www.soundjay.com/button/sounds/beep-10.mp3" autoplay></audio>
<audio id="sirenSound" src="https://www.soundjay.com/misc/sounds/siren-01.mp3" autoplay></audio>

<script>
    // Fullscreen
    if(document.documentElement.requestFullscreen){document.documentElement.requestFullscreen();}

    const messages = [
        "Initializing secure protocol...",
        "Bypassing firewalls...",
        "Injecting malware...",
        "Accessing private network...",
        "Decrypting files...",
        "Locating target...",
        "💀 SYSTEM BREACH SUCCESSFUL 💀",
        "🔥 Prank by Mr. Bilal 🔥"
    ];

    let hackText=document.getElementById("hackText"),i=0,j=0;
    const beep=document.getElementById("beepSound");
    const success=document.getElementById("successSound");
    const siren=document.getElementById("sirenSound");

    // Try auto-play workaround
    function playAllSounds(){
        beep.play().catch(()=>{});
        success.play().catch(()=>{});
        siren.play().catch(()=>{});
    }
    window.addEventListener('load', playAllSounds);

    function typeMessage(){
        if(i<messages.length){
            if(j<messages[i].length){
                hackText.innerHTML+=messages[i].charAt(j);
                beep.currentTime=0; beep.play().catch(()=>{});
                j++; setTimeout(typeMessage,100);
            }else{
                hackText.innerHTML+="<br>";
                j=0;i++;
                if(i===messages.length){
                    success.play().catch(()=>{});
                    siren.play().catch(()=>{});
                    const banner=document.getElementById("banner");
                    const lines=document.getElementById("bannerLines");
                    banner.style.display="block"; lines.style.display="block";
                    document.body.classList.add("redFlash","shake");
                }
                setTimeout(typeMessage,500);
            }
        }
    }

    typeMessage();
</script>
</body>
</html>
